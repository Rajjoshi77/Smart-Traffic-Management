# Backend environment variables (example)
# Copy to .env and fill values before deploying

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/traffic_iq?retryWrites=true&w=majority
DB_NAME=traffic_iq

# Kafka (if using Kafka producer/consumer)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=traffic_sensor_data

# OpenWeather API
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather

# Spark
SPARK_MASTER=local[*]
SPARK_APP_NAME=TrafficIQAnalytics

# App
PORT=8000

